EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=<your-mapbox-public-token>

# Background location adapter: "transistor" (paid plugin, default) or "expo" (free)
EXPO_PUBLIC_BG_LOCATION_ADAPTER=transistor

# Transistor plugin license keys (only needed when adapter is "transistor")
EXPO_PUBLIC_TRANSISTOR_IOS_LICENSE=
EXPO_PUBLIC_TRANSISTOR_ANDROID_LICENSE=

# Copy this file to .env.local and fill in the values
