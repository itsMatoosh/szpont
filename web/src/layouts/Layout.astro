---
import type { Locale } from '@/i18n/utils';
import { t } from '@/i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { VISITOR_COOKIE_SCRIPT } from '@/lib/visitor';
import Analytics from '@vercel/analytics/astro'

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const pageTitle = title ?? t(locale, 'meta.title');
const pageDescription = description ?? t(locale, 'meta.description');
const basePath = Astro.url.pathname.replace(/^\/pl/, '') || '/';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Szpont" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="alternate" hreflang="en" href={getRelativeLocaleUrl('en', basePath)} />
    <link rel="alternate" hreflang="pl" href={getRelativeLocaleUrl('pl', basePath)} />
    <script is:inline set:html={VISITOR_COOKIE_SCRIPT} />

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="bg-background text-foreground min-h-screen font-sans antialiased">
    <slot />
    <Analytics />
  </body>
</html>
