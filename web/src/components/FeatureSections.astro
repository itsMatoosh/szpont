---
import type { Locale } from '@/i18n/utils';
import { t } from '@/i18n/utils';
import AccentTitle from './AccentTitle.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<!-- Section 2: Find your squad -->
<section class="py-20 md:py-32 px-5 md:px-8 flex flex-col items-center bg-surface">
  <div class="max-w-2xl w-full flex flex-col items-center gap-8">
    <!-- Card stack with profile photos, matching mobile SlideMatching -->
    <div class="relative w-48 h-64 md:w-56 md:h-72 mx-auto">
      <div class="absolute inset-0 rounded-3xl overflow-hidden -rotate-6 -translate-x-4 opacity-50 border border-border">
        <img src="/images/swipe-2.jpg" alt="" class="w-full h-full object-cover" />
      </div>
      <div class="absolute inset-0 rounded-3xl overflow-hidden rotate-3 translate-x-2 border border-border">
        <img src="/images/swipe-1.jpg" alt="" class="w-full h-full object-cover" />
        <div class="absolute bottom-4 left-0 right-0 flex justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#CCFF00" class="w-9 h-9">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
          </svg>
        </div>
      </div>
    </div>

    <AccentTitle
      before={t(locale, 'slide2.titleBefore')}
      accent={t(locale, 'slide2.titleAccent')}
    />
    <p class="text-muted text-base md:text-lg text-center leading-relaxed whitespace-pre-line">
      {t(locale, 'slide2.subtitle')}
    </p>
  </div>
</section>

<!-- Section 3: Meetup zones -->
<section class="py-20 md:py-32 px-5 md:px-8 flex flex-col items-center">
  <div class="max-w-2xl w-full flex flex-col items-center gap-8">
    <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl icon-bg flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 md:w-12 md:h-12 text-accent">
        <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
      </svg>
    </div>
    <AccentTitle
      before={t(locale, 'slide3.titleBefore')}
      accent={t(locale, 'slide3.titleAccent')}
      after={t(locale, 'slide3.titleAfter')}
      large
    />
  </div>
</section>

<!-- Section 4: Zone explanation — map illustration with avatars -->
<section class="py-20 md:py-32 px-5 md:px-8 flex flex-col items-center bg-surface">
  <div class="max-w-2xl w-full flex flex-col items-center gap-8">
    <!-- Map illustration matching mobile SlideZoneExplanation -->
    <div class="relative w-full max-w-sm aspect-square rounded-3xl overflow-hidden">
      <picture>
        <source srcset="/images/map-bg-dark.jpg" media="(prefers-color-scheme: dark)" />
        <img src="/images/map-bg-light.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />
      </picture>
      <!-- Accent zone glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[55%] aspect-square rounded-full bg-accent map-glow"></div>
      <!-- Avatars scattered on the map -->
      <div class="absolute rounded-full overflow-hidden border-2 border-accent" style="width:48px;height:48px;top:22%;left:25%">
        <img src="/images/avatar-1.jpg" alt="" class="w-full h-full object-cover" />
      </div>
      <div class="absolute rounded-full overflow-hidden border-2 border-accent" style="width:44px;height:44px;top:30%;right:22%">
        <img src="/images/avatar-2.jpg" alt="" class="w-full h-full object-cover" />
      </div>
      <div class="absolute rounded-full overflow-hidden border-2 border-accent" style="width:46px;height:46px;top:52%;left:35%">
        <img src="/images/avatar-3.jpg" alt="" class="w-full h-full object-cover" />
      </div>
      <div class="absolute rounded-full overflow-hidden border-2 border-accent" style="width:42px;height:42px;top:42%;right:30%">
        <img src="/images/avatar-4.jpg" alt="" class="w-full h-full object-cover" />
      </div>
    </div>

    <AccentTitle
      before={t(locale, 'slide4.titleBefore')}
      accent={t(locale, 'slide4.titleAccent')}
    />
    <div class="flex items-center gap-3 bg-surface border border-border rounded-2xl px-5 py-4">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 shrink-0 text-muted">
        <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 00-5.25 5.25v3a3 3 0 00-3 3v6.75a3 3 0 003 3h10.5a3 3 0 003-3v-6.75a3 3 0 00-3-3v-3c0-2.9-2.35-5.25-5.25-5.25zm3.75 8.25v-3a3.75 3.75 0 10-7.5 0v3h7.5z" clip-rule="evenodd" />
      </svg>
      <p class="text-muted text-base leading-relaxed">
        {t(locale, 'slide4.subtitle')}
      </p>
    </div>
  </div>
</section>

<style>
  /* Gray in light mode for contrast against light backgrounds; accent tint in dark mode */
  .icon-bg {
    background-color: var(--highlight);
  }
  @media (prefers-color-scheme: dark) {
    .icon-bg {
      background-color: rgba(204, 255, 0, 0.15);
    }
  }

  /* Black outline on accent SVG icons in light mode for visibility */
  @media (prefers-color-scheme: light) {
    .icon-bg svg {
      stroke: #000;
      stroke-width: 1px;
      paint-order: stroke fill;
    }
  }

  /* Accent glow opacity adapts to color scheme, matching mobile's 25% light / 15% dark */
  .map-glow {
    opacity: 0.25;
  }
  @media (prefers-color-scheme: dark) {
    .map-glow {
      opacity: 0.15;
    }
  }
</style>

<!-- Section 5: Green light -->
<section class="py-20 md:py-32 px-5 md:px-8 flex flex-col items-center">
  <div class="max-w-2xl w-full flex flex-col items-center gap-8">
    <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl icon-bg flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 md:w-12 md:h-12 text-accent">
        <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
      </svg>
    </div>
    <AccentTitle
      before={t(locale, 'slide5.titleBefore')}
      accent={t(locale, 'slide5.titleAccent')}
      large
    />
    <p class="text-muted text-base md:text-xl text-center leading-relaxed">
      {t(locale, 'slide5.subtitle')}
    </p>
  </div>
</section>
