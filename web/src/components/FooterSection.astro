---
import type { Locale } from '@/i18n/utils';
import { t } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<footer class="py-12 px-5 md:px-8 flex flex-col items-center gap-6 border-t border-border">
  <a
    href="#hero"
    class="min-h-[48px] leading-[48px] px-8 rounded-xl bg-accent text-on-accent font-semibold text-base text-center hover:opacity-90 transition-opacity"
  >
    {t(locale, 'footer.joinWaitlist')}
  </a>
  <a
    href="https://instagram.com/szpont.app"
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-2 text-muted hover:text-foreground text-sm transition-colors"
  >
    <!-- Instagram icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    </svg>
    {t(locale, 'footer.instagram')}
  </a>
  <p class="text-muted text-sm">{t(locale, 'footer.copyright')}</p>
</footer>
