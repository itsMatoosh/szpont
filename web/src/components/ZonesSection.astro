---
import type { Locale } from '@/i18n/utils';
import { t, localePath } from '@/i18n/utils';

interface Zone {
  id: string;
  name: string;
  zone_likes: { count: number }[];
}

interface City {
  id: string;
  name: string;
  search_boundary: unknown;
  zones: Zone[];
}

interface Props {
  locale: Locale;
  cities: City[];
}

const { locale, cities } = Astro.props;

/** A city is linkable when it has a boundary and at least one active zone. */
function isLinkable(city: City): boolean {
  return city.search_boundary != null && city.zones.length > 0;
}
---

<section id="zones" class="py-20 md:py-32 px-5 md:px-8 flex flex-col items-center bg-surface">
  <div class="max-w-3xl w-full flex flex-col items-center gap-12">
    <div class="flex flex-col items-center gap-4">
      <h2 class="text-2xl md:text-4xl font-bold text-center text-foreground">
        {t(locale, 'zones.title')}
      </h2>
      <p class="text-muted text-base md:text-lg text-center leading-relaxed max-w-xl">
        {t(locale, 'zones.subtitle')}
      </p>
    </div>

    {cities.length > 0 && (
      <div class="flex flex-col gap-10 w-full">
        {cities.map((city) => {
          const linkable = isLinkable(city);
          const cityHref = localePath(locale, `/city/${city.id}`);
          return (
            <div class="flex flex-col gap-4">
              {/* City header */}
              {linkable ? (
                <a
                  href={cityHref}
                  class="group inline-flex items-center gap-2 self-start"
                >
                  <h3 class="text-xl md:text-2xl font-bold text-foreground group-hover:text-accent transition-colors">
                    {city.name}
                  </h3>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-muted group-hover:text-accent transition-colors">
                    <path fill-rule="evenodd" d="M16.28 11.47a.75.75 0 010 1.06l-7.5 7.5a.75.75 0 01-1.06-1.06L14.69 12 7.72 5.03a.75.75 0 011.06-1.06l7.5 7.5z" clip-rule="evenodd" />
                  </svg>
                </a>
              ) : (
                <h3 class="text-xl md:text-2xl font-bold text-foreground">
                  {city.name}
                </h3>
              )}

              {/* Active zones */}
              {city.zones.length > 0 && (
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">
                    {t(locale, 'zones.activeLabel')}
                  </p>
                  <div class="active-container grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3" data-city-id={city.id}>
                    {city.zones.map((zone) =>
                      linkable ? (
                        <div class="zone-row flex items-center gap-2" data-zone-id={zone.id}>
                          <a
                            href={cityHref}
                            class="zone-card group flex items-center gap-3 bg-surface border border-border rounded-2xl px-4 py-3 hover:border-accent transition-colors flex-1"
                          >
                            <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-accent/15 shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-accent">
                                <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                              </svg>
                            </span>
                            <span class="font-semibold text-foreground group-hover:text-accent transition-colors flex-1">
                              {zone.name}
                            </span>
                          </a>
                          <span class="zone-like-placeholder"></span>
                        </div>
                      ) : (
                        <div class="zone-row flex items-center gap-2" data-zone-id={zone.id}>
                          <div class="zone-card flex items-center gap-3 bg-surface border border-border rounded-2xl px-4 py-3 flex-1">
                            <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-accent/15 shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-accent">
                                <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                              </svg>
                            </span>
                            <span class="font-semibold text-foreground flex-1">
                              {zone.name}
                            </span>
                          </div>
                          <span class="zone-like-placeholder"></span>
                        </div>
                      )
                    )}
                  </div>
                </div>
              )}

              {/* Proposed zones (filled client-side) */}
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">
                  {t(locale, 'zones.proposedLabel')}
                </p>
                <div
                  class="proposed-container grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3"
                  data-city-id={city.id}
                  data-linkable={linkable ? 'true' : 'false'}
                  data-city-href={linkable ? cityHref : ''}
                >
                  <p class="proposed-empty text-sm text-muted col-span-full">
                    {t(locale, 'zones.noProposed')}
                  </p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}

    <a
      href={localePath(locale, '/suggest-zone')}
      class="inline-block min-h-[48px] leading-[48px] px-8 rounded-xl bg-accent text-on-accent font-semibold text-base text-center hover:opacity-90 transition-opacity"
    >
      {t(locale, 'zones.suggestButton')}
    </a>
  </div>
</section>

<style is:global>
  @media (prefers-color-scheme: light) {
    .zone-pin {
      stroke: #000;
      stroke-width: 1px;
      paint-order: stroke fill;
    }
    .like-btn:disabled svg {
      stroke: #000;
      stroke-width: 1px;
      paint-order: stroke fill;
    }
    .like-btn:disabled span {
      color: var(--foreground);
    }
  }
</style>

<script is:inline id="zones-i18n" type="application/json" set:html={JSON.stringify({
  like: t(locale, 'zones.likeButton'),
  liked: t(locale, 'zones.liked'),
  noProposed: t(locale, 'zones.noProposed'),
})} />

<script>
  import { supabase } from '@/lib/supabase';

  const i18n = JSON.parse(document.getElementById('zones-i18n')!.textContent!) as {
    like: string;
    liked: string;
    noProposed: string;
  };

  const FILLED_HEART = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" /></svg>';
  const OUTLINE_HEART = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>';
  const PIN_SVG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-accent"><path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" /></svg>';
  const SUGGESTED_PIN_SVG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-[#FF9500]"><path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" /></svg>';

  const VISITOR_KEY = 'szpont_visitor_id';

  /** Returns a persistent visitor ID, creating one if needed. */
  function getVisitorId(): string {
    let id = localStorage.getItem(VISITOR_KEY);
    if (!id) {
      id = crypto.randomUUID();
      localStorage.setItem(VISITOR_KEY, id);
    }
    return id;
  }

  /** Creates a like button element wired to insert into the given table. */
  function createLikeButton(opts: {
    likeCount: number;
    alreadyLiked: boolean;
    table: 'zone_likes' | 'zone_suggestion_likes';
    fkColumn: string;
    fkValue: string;
    visitorId: string;
  }): HTMLButtonElement {
    const { likeCount, alreadyLiked, table, fkColumn, fkValue, visitorId } = opts;

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'like-btn flex items-center gap-1.5 text-sm font-semibold transition-colors cursor-pointer '
      + (alreadyLiked ? 'text-accent' : 'text-muted hover:text-accent');
    if (alreadyLiked) btn.disabled = true;

    const countSpan = document.createElement('span');
    countSpan.textContent = String(likeCount);

    btn.innerHTML = alreadyLiked ? FILLED_HEART : OUTLINE_HEART;
    btn.appendChild(countSpan);

    if (!alreadyLiked) {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();

        // Optimistic update: show liked state immediately
        btn.disabled = true;
        btn.classList.remove('text-muted', 'hover:text-accent');
        btn.classList.add('text-accent');
        countSpan.textContent = String(likeCount + 1);
        btn.querySelector('svg')!.outerHTML = FILLED_HEART;

        const { error } = await supabase.from(table).insert({
          [fkColumn]: fkValue,
          visitor_id: visitorId,
        });

        // Roll back on failure
        if (error) {
          btn.disabled = false;
          btn.classList.remove('text-accent');
          btn.classList.add('text-muted', 'hover:text-accent');
          countSpan.textContent = String(likeCount);
          btn.querySelector('svg')!.outerHTML = OUTLINE_HEART;
        }
      });
    }

    return btn;
  }

  async function init() {
    const proposedContainers = document.querySelectorAll<HTMLElement>('.proposed-container');
    const activeContainers = document.querySelectorAll<HTMLElement>('.active-container');
    if (proposedContainers.length === 0 && activeContainers.length === 0) return;

    const cityIds = Array.from(proposedContainers).map((el) => el.dataset.cityId!);
    const visitorId = getVisitorId();

    // Fetch all data in parallel: suggestions + counts, zone like counts, visitor's likes for both
    const [suggestionsRes, mySuggestionLikesRes, zoneLikeCountsRes, myZoneLikesRes] = await Promise.all([
      supabase
        .from('zone_suggestions')
        .select('id, name, city_id, zone_suggestion_likes(count)')
        .in('city_id', cityIds),
      supabase
        .from('zone_suggestion_likes')
        .select('suggestion_id')
        .eq('visitor_id', visitorId),
      supabase
        .from('zones')
        .select('id, zone_likes(count)'),
      supabase
        .from('zone_likes')
        .select('zone_id')
        .eq('visitor_id', visitorId),
    ]);

    // --- Active zones: inject like buttons ---
    const zoneLikeCounts = new Map<string, number>();
    for (const z of zoneLikeCountsRes.data ?? []) {
      const count = (z.zone_likes as unknown as { count: number }[])?.[0]?.count ?? 0;
      zoneLikeCounts.set(z.id, count);
    }
    const likedZoneIds = new Set((myZoneLikesRes.data ?? []).map((r) => r.zone_id));

    for (const container of activeContainers) {
      const rows = container.querySelectorAll<HTMLElement>('.zone-row');
      for (const row of rows) {
        const zoneId = row.dataset.zoneId!;
        const likeCount = zoneLikeCounts.get(zoneId) ?? 0;
        const alreadyLiked = likedZoneIds.has(zoneId);

        const placeholder = row.querySelector('.zone-like-placeholder');
        if (placeholder) {
          const btn = createLikeButton({
            likeCount,
            alreadyLiked,
            table: 'zone_likes',
            fkColumn: 'zone_id',
            fkValue: zoneId,
            visitorId,
          });
          placeholder.replaceWith(btn);
        }
      }
    }

    // --- Proposed zones: render cards client-side ---
    const suggestions = suggestionsRes.data ?? [];
    const likedSuggestionIds = new Set((mySuggestionLikesRes.data ?? []).map((r) => r.suggestion_id));

    const byCityId = new Map<string, typeof suggestions>();
    for (const s of suggestions) {
      if (!s.city_id) continue;
      const arr = byCityId.get(s.city_id) ?? [];
      arr.push(s);
      byCityId.set(s.city_id, arr);
    }

    for (const container of proposedContainers) {
      const cityId = container.dataset.cityId!;
      const linkable = container.dataset.linkable === 'true';
      const cityHref = container.dataset.cityHref || '';
      const citySuggestions = byCityId.get(cityId) ?? [];

      citySuggestions.sort((a, b) => {
        const countA = (a.zone_suggestion_likes as unknown as { count: number }[])?.[0]?.count ?? 0;
        const countB = (b.zone_suggestion_likes as unknown as { count: number }[])?.[0]?.count ?? 0;
        return countB - countA;
      });

      const emptyMsg = container.querySelector('.proposed-empty');

      if (citySuggestions.length === 0) {
        if (emptyMsg) emptyMsg.classList.remove('hidden');
        continue;
      }

      if (emptyMsg) emptyMsg.classList.add('hidden');

      for (const suggestion of citySuggestions) {
        const likeCount = (suggestion.zone_suggestion_likes as unknown as { count: number }[])?.[0]?.count ?? 0;
        const alreadyLiked = likedSuggestionIds.has(suggestion.id);

        const row = document.createElement('div');
        row.className = 'zone-row flex items-center gap-2';

        const card = document.createElement(linkable ? 'a' : 'div');
        card.className = 'zone-card flex items-center gap-3 bg-surface border border-border rounded-2xl px-4 py-3 flex-1'
          + (linkable ? ' hover:border-[#FF9500] transition-colors group' : '');
        if (linkable && card instanceof HTMLAnchorElement) {
          card.href = cityHref;
        }

        const pinIcon = document.createElement('span');
        pinIcon.className = 'flex items-center justify-center w-7 h-7 rounded-lg bg-[#FF9500]/15 shrink-0';
        pinIcon.innerHTML = SUGGESTED_PIN_SVG;

        const nameEl = document.createElement('span');
        nameEl.className = 'font-semibold text-foreground flex-1' + (linkable ? ' group-hover:text-[#FF9500] transition-colors' : '');
        nameEl.textContent = suggestion.name;

        card.appendChild(pinIcon);
        card.appendChild(nameEl);

        const likeBtn = createLikeButton({
          likeCount,
          alreadyLiked,
          table: 'zone_suggestion_likes',
          fkColumn: 'suggestion_id',
          fkValue: suggestion.id,
          visitorId,
        });

        row.appendChild(card);
        row.appendChild(likeBtn);
        container.appendChild(row);
      }
    }

  }

  init();
</script>
