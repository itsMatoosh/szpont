---
import type { Locale } from '@/i18n/utils';
import { t, localePath } from '@/i18n/utils';

interface Zone {
  id: string;
  name: string;
  zone_likes: { count: number }[];
}

interface Suggestion {
  id: string;
  name: string;
  zone_suggestion_likes: { count: number }[];
}

interface City {
  id: string;
  name: string;
  zones: Zone[];
  suggestions: Suggestion[];
}

interface Props {
  locale: Locale;
  cities: City[];
  likedZoneIds: Set<string>;
  likedSuggestionIds: Set<string>;
}

const { locale, cities, likedZoneIds, likedSuggestionIds } = Astro.props;

/** A city is linkable when it has at least one active or proposed zone. */
function isLinkable(city: City): boolean {
  return city.zones.length > 0 || city.suggestions.length > 0;
}

/** Extracts the like count from a nested Supabase aggregate. */
function zoneLikeCount(z: Zone): number {
  return z.zone_likes?.[0]?.count ?? 0;
}
function suggestionLikeCount(s: Suggestion): number {
  return s.zone_suggestion_likes?.[0]?.count ?? 0;
}
---

<section id="zones" class="py-20 md:py-32 px-5 md:px-8 flex flex-col items-center bg-surface">
  <div class="max-w-3xl w-full flex flex-col items-center gap-12">
    <div class="flex flex-col items-center gap-4">
      <h2 class="text-2xl md:text-4xl font-bold text-center text-foreground">
        {t(locale, 'zones.title')}
      </h2>
      <p class="text-muted text-base md:text-lg text-center leading-relaxed max-w-xl">
        {t(locale, 'zones.subtitle')}
      </p>
    </div>

    {cities.length > 0 && (
      <div class="flex flex-col gap-10 w-full">
        {cities.map((city) => {
          const linkable = isLinkable(city);
          const cityHref = localePath(locale, `/city/${city.id}`);
          return (
            <div class="flex flex-col gap-4">
              {/* City header */}
              {linkable ? (
                <a
                  href={cityHref}
                  class="group inline-flex items-center gap-2 self-start"
                >
                  <h3 class="text-xl md:text-2xl font-bold text-foreground group-hover:text-accent transition-colors">
                    {city.name}
                  </h3>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-muted group-hover:text-accent transition-colors">
                    <path fill-rule="evenodd" d="M16.28 11.47a.75.75 0 010 1.06l-7.5 7.5a.75.75 0 01-1.06-1.06L14.69 12 7.72 5.03a.75.75 0 011.06-1.06l7.5 7.5z" clip-rule="evenodd" />
                  </svg>
                </a>
              ) : (
                <h3 class="text-xl md:text-2xl font-bold text-foreground">
                  {city.name}
                </h3>
              )}

              {/* Active zones */}
              {city.zones.length > 0 && (
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">
                    {t(locale, 'zones.activeLabel')}
                  </p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
                    {city.zones.map((zone) => {
                      const liked = likedZoneIds.has(zone.id);
                      const count = zoneLikeCount(zone);
                      return (
                        <div class="flex items-center gap-2">
                          {linkable ? (
                            <a
                              href={cityHref}
                              class="zone-card group flex items-center gap-3 bg-surface border border-border rounded-2xl px-4 py-3 hover:border-accent transition-colors flex-1"
                            >
                              <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-accent/15 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-accent">
                                  <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                                </svg>
                              </span>
                              <span class="font-semibold text-foreground group-hover:text-accent transition-colors flex-1">
                                {zone.name}
                              </span>
                            </a>
                          ) : (
                            <div class="zone-card flex items-center gap-3 bg-surface border border-border rounded-2xl px-4 py-3 flex-1">
                              <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-accent/15 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-accent">
                                  <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                                </svg>
                              </span>
                              <span class="font-semibold text-foreground flex-1">
                                {zone.name}
                              </span>
                            </div>
                          )}
                          <button
                            type="button"
                            class:list={[
                              'like-btn flex items-center gap-1.5 text-sm font-semibold transition-colors',
                              liked ? 'text-accent' : 'text-muted hover:text-accent cursor-pointer',
                            ]}
                            disabled={liked}
                            data-like-table="zone_likes"
                            data-like-fk="zone_id"
                            data-like-id={zone.id}
                            data-like-count={count}
                          >
                            {liked ? (
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="like-icon w-4 h-4"><path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" /></svg>
                            ) : (
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="like-icon w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
                            )}
                            <span class="like-count">{count}</span>
                          </button>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}

              {/* Proposed zones */}
              {city.suggestions.length > 0 && (
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">
                    {t(locale, 'zones.proposedLabel')}
                  </p>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
                    {city.suggestions.map((suggestion) => {
                      const liked = likedSuggestionIds.has(suggestion.id);
                      const count = suggestionLikeCount(suggestion);
                      return (
                        <div class="flex items-center gap-2">
                          {linkable ? (
                            <a
                              href={cityHref}
                              class="zone-card group flex items-center gap-3 bg-surface border border-border rounded-2xl px-4 py-3 hover:border-[#FF9500] transition-colors flex-1"
                            >
                              <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-[#FF9500]/15 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-[#FF9500]">
                                  <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                                </svg>
                              </span>
                              <span class="font-semibold text-foreground group-hover:text-[#FF9500] transition-colors flex-1">
                                {suggestion.name}
                              </span>
                            </a>
                          ) : (
                            <div class="zone-card flex items-center gap-3 bg-surface border border-border rounded-2xl px-4 py-3 flex-1">
                              <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-[#FF9500]/15 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="zone-pin w-4 h-4 text-[#FF9500]">
                                  <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 3.827 3.024ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                                </svg>
                              </span>
                              <span class="font-semibold text-foreground flex-1">
                                {suggestion.name}
                              </span>
                            </div>
                          )}
                          <button
                            type="button"
                            class:list={[
                              'like-btn flex items-center gap-1.5 text-sm font-semibold transition-colors',
                              liked ? 'text-accent' : 'text-muted hover:text-accent cursor-pointer',
                            ]}
                            disabled={liked}
                            data-like-table="zone_suggestion_likes"
                            data-like-fk="suggestion_id"
                            data-like-id={suggestion.id}
                            data-like-count={count}
                          >
                            {liked ? (
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="like-icon w-4 h-4"><path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" /></svg>
                            ) : (
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="like-icon w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
                            )}
                            <span class="like-count">{count}</span>
                          </button>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    )}

    <a
      href={localePath(locale, '/suggest-zone')}
      class="inline-block min-h-[48px] leading-[48px] px-8 rounded-xl bg-accent text-on-accent font-semibold text-base text-center hover:opacity-90 transition-opacity"
    >
      {t(locale, 'zones.suggestButton')}
    </a>
  </div>
</section>

<style is:global>
  @media (prefers-color-scheme: light) {
    .zone-pin {
      stroke: #000;
      stroke-width: 1px;
      paint-order: stroke fill;
    }
    .like-btn:disabled svg {
      stroke: #000;
      stroke-width: 1px;
      paint-order: stroke fill;
    }
    .like-btn:disabled span {
      color: var(--foreground);
    }
  }
</style>

<script>
  import { supabase } from '@/lib/supabase';
  import { VISITOR_COOKIE_NAME } from '@/lib/visitor';

  const FILLED_HEART = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="like-icon w-4 h-4"><path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" /></svg>';

  /** Reads the visitor_id from the cookie. */
  function readVisitorId(): string | null {
    const match = document.cookie.match(new RegExp('(?:^|; )' + VISITOR_COOKIE_NAME + '=([^;]*)'));
    return match ? decodeURIComponent(match[1]) : null;
  }

  for (const btn of document.querySelectorAll<HTMLButtonElement>('.like-btn:not(:disabled)')) {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const table = btn.dataset.likeTable as 'zone_likes' | 'zone_suggestion_likes';
      const fkColumn = btn.dataset.likeFk!;
      const fkValue = btn.dataset.likeId!;
      const currentCount = Number(btn.dataset.likeCount ?? 0);
      const visitorId = readVisitorId();
      if (!visitorId) return;

      const countEl = btn.querySelector('.like-count')!;
      const iconEl = btn.querySelector('.like-icon')!;

      // Optimistic update
      btn.disabled = true;
      btn.classList.remove('text-muted', 'hover:text-accent', 'cursor-pointer');
      btn.classList.add('text-accent');
      countEl.textContent = String(currentCount + 1);
      iconEl.outerHTML = FILLED_HEART;

      const { error } = await supabase.from(table).insert({
        [fkColumn]: fkValue,
        visitor_id: visitorId,
      });

      if (error) {
        btn.disabled = false;
        btn.classList.remove('text-accent');
        btn.classList.add('text-muted', 'hover:text-accent', 'cursor-pointer');
        countEl.textContent = String(currentCount);
      }
    });
  }
</script>
