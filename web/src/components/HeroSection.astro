---
import type { Locale } from '@/i18n/utils';
import { t } from '@/i18n/utils';
import AccentTitle from './AccentTitle.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center px-5 md:px-8">
  <div class="max-w-2xl w-full flex flex-col items-center text-center gap-10">
    <img src="/szpont-logo.svg" alt="Szpont" class="h-12 md:h-16 w-auto" />

    <AccentTitle
      before={t(locale, 'hero.titleBefore')}
      accent={t(locale, 'hero.titleAccent')}
      large
    />

    <!-- Waitlist form -->
    <form id="waitlist-form" class="w-full max-w-sm flex flex-col gap-3 items-center">
      <input
        type="email"
        id="waitlist-email"
        required
        placeholder={t(locale, 'waitlist.placeholder')}
        class="w-full min-h-[48px] px-4 py-3 rounded-xl bg-surface border border-border text-foreground text-base placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent"
      />
      <p id="waitlist-email-error" class="text-red-500 text-sm hidden">
        {t(locale, 'waitlist.invalidEmail')}
      </p>
      <button
        type="submit"
        class="w-full min-h-[48px] rounded-xl bg-accent text-on-accent font-semibold text-base cursor-pointer hover:opacity-90 transition-opacity"
      >
        {t(locale, 'waitlist.button')}
      </button>
    </form>

    <a href="#zones" class="text-muted text-sm hover:text-accent transition-colors underline underline-offset-4">
      {t(locale, 'waitlist.suggestZoneLink')}
    </a>

    <div id="waitlist-success" class="w-full max-w-sm min-h-[48px] rounded-xl bg-highlight flex items-center justify-center hidden" data-template={t(locale, 'waitlist.success')}>
      <p class="text-primary font-bold text-base" id="waitlist-success-text"></p>
    </div>
    <p id="waitlist-already" class="text-muted font-semibold text-lg hidden">
      {t(locale, 'waitlist.alreadyOnList')}
    </p>
    <p id="waitlist-error" class="text-red-500 font-semibold text-lg hidden">
      {t(locale, 'waitlist.error')}
    </p>
  </div>

  <!-- Instagram CTA -->
  <a
    href="https://instagram.com/szpont.app"
    target="_blank"
    rel="noopener noreferrer"
    class="absolute bottom-20 flex items-center gap-2 text-muted hover:text-foreground text-sm transition-colors"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    </svg>
    {t(locale, 'footer.instagram')}
  </a>

  <!-- Animated scroll-down hint with label -->
  <div class="absolute bottom-6 scroll-hint flex items-center gap-2 text-muted text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
    <span>{t(locale, 'scrollHint')}</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>
</section>

<style>
  /* Gentle bounce that slides the chevron up and down */
  @keyframes bounce-scroll {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(6px); opacity: 1; }
  }
  .scroll-hint {
    animation: bounce-scroll 1.8s ease-in-out infinite;
  }
</style>

<script>
  // Fade out the scroll hint once the user starts scrolling
  const hint = document.querySelector('.scroll-hint') as HTMLElement | null;
  if (hint) {
    let hidden = false;
    window.addEventListener('scroll', () => {
      if (hidden) return;
      if (window.scrollY > 80) {
        hint.style.opacity = '0';
        hint.style.transition = 'opacity 0.4s ease';
        hidden = true;
      }
    }, { passive: true });
  }
</script>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const emailInput = document.getElementById('waitlist-email') as HTMLInputElement;
  const emailError = document.getElementById('waitlist-email-error')!;
  const successEl = document.getElementById('waitlist-success')!;
  const successText = document.getElementById('waitlist-success-text')!;
  const alreadyMsg = document.getElementById('waitlist-already')!;
  const errorMsg = document.getElementById('waitlist-error')!;

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    emailError.classList.add('hidden');
    successEl.classList.add('hidden');
    alreadyMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    const email = emailInput.value.trim();
    if (!emailRegex.test(email)) {
      emailError.classList.remove('hidden');
      return;
    }

    const { data, error } = await supabase
      .from('waitlist')
      .insert({ email })
      .select('position')
      .single();

    if (error) {
      if (error.code === '23505') {
        form.classList.add('hidden');
        alreadyMsg.classList.remove('hidden');
      } else {
        errorMsg.classList.remove('hidden');
      }
      return;
    }

    const template = successEl.dataset.template ?? '';
    successText.textContent = template.replace('{{number}}', String(data.position));
    form.classList.add('hidden');
    successEl.classList.remove('hidden');
  });
</script>
