---
import Layout from '@/layouts/Layout.astro';
import { t, localePath, localeFromParam } from '@/i18n/utils';
import { supabase } from '@/lib/supabase';

const locale = localeFromParam(Astro.params.locale);
const cityId = Astro.params.id;

const [{ data: city }, { data: zones }, { data: suggestions }] = await Promise.all([
  supabase.from('cities').select('id, name').eq('id', cityId).single(),
  supabase.from('zones').select('id, name, boundary').eq('city_id', cityId),
  supabase.from('zone_suggestions').select('id, name, boundary').eq('city_id', cityId),
]);

if (!city) return Astro.redirect(localePath(locale, '/'));
---

<Layout locale={locale} title={`${city.name} — Szpont`}>
  <div class="relative w-full h-screen">
    <div id="map" class="w-full h-full" style="width:100%;height:100vh"></div>

    <!-- Back button -->
    <a
      href={localePath(locale, '/')}
      class="absolute top-4 left-4 z-10 flex items-center gap-2 bg-surface/90 backdrop-blur border border-border rounded-xl px-4 py-2 text-foreground font-semibold text-sm hover:border-accent transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
        <path fill-rule="evenodd" d="M7.72 12.53a.75.75 0 010-1.06l7.5-7.5a.75.75 0 111.06 1.06L9.31 12l6.97 6.97a.75.75 0 11-1.06 1.06l-7.5-7.5z" clip-rule="evenodd" />
      </svg>
      {t(locale, 'cityMap.back')}
    </a>

    <!-- Layer toggle pills -->
    <div class="absolute top-16 left-4 z-10 flex flex-col gap-2">
      <button
        id="toggle-active"
        class="flex items-center gap-2 bg-surface/90 backdrop-blur border border-border rounded-xl px-4 py-2 text-foreground font-semibold text-sm hover:border-accent transition-colors cursor-pointer"
      >
        <span class="w-3 h-3 rounded-full bg-[#CCFF00] shrink-0"></span>
        {t(locale, 'cityMap.activeZones')}
      </button>
      <button
        id="toggle-suggested"
        class="flex items-center gap-2 bg-surface/90 backdrop-blur border border-border rounded-xl px-4 py-2 text-foreground font-semibold text-sm hover:border-accent transition-colors cursor-pointer"
      >
        <span class="w-3 h-3 rounded-full bg-[#FF9500] shrink-0"></span>
        {t(locale, 'cityMap.suggestedZones')}
      </button>
    </div>

    <!-- Floating suggest button -->
    <a
      href={localePath(locale, '/suggest-zone')}
      class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 min-h-[48px] leading-[48px] px-8 rounded-full bg-accent text-on-accent font-semibold text-base text-center shadow-lg hover:opacity-90 transition-opacity whitespace-nowrap"
    >
      {t(locale, 'cityMap.suggestButton')}
    </a>
  </div>
  <script
    is:inline
    id="city-data"
    type="application/json"
    set:html={JSON.stringify({
      zones: (zones ?? []).map(z => ({ name: z.name, boundary: z.boundary })),
      suggestions: (suggestions ?? []).map(s => ({ name: s.name, boundary: s.boundary })),
    })}
  />
</Layout>

<script>
  import mapboxgl from 'mapbox-gl';
  import 'mapbox-gl/dist/mapbox-gl.css';

  type ZoneEntry = { name: string; boundary: unknown };

  const dataEl = document.getElementById('city-data')!;
  const { zones, suggestions } = JSON.parse(dataEl.textContent!) as {
    zones: ZoneEntry[];
    suggestions: ZoneEntry[];
  };

  const ACTIVE_COLOR = '#CCFF00';
  const SUGGESTED_COLOR = '#FF9500';

  const token = import.meta.env.PUBLIC_MAPBOX_ACCESS_TOKEN;
  mapboxgl.accessToken = token;

  const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const style = isDark
    ? 'mapbox://styles/mapbox/dark-v11'
    : 'mapbox://styles/mapbox/light-v11';

  const map = new mapboxgl.Map({
    container: 'map',
    style,
    center: [0, 0],
    zoom: 2,
  });

  map.addControl(new mapboxgl.NavigationControl(), 'top-right');

  /** Layer IDs grouped by category so toggles can flip them in bulk. */
  const activeLayerIds: string[] = [];
  const suggestedLayerIds: string[] = [];

  map.on('load', () => {
    // Re-measure canvas in case mapbox-gl.css loaded after map init
    map.resize();

    const allCoords = [
      ...zones.flatMap(z => extractCoordinates(z.boundary)),
      ...suggestions.flatMap(s => extractCoordinates(s.boundary)),
    ];

    if (allCoords.length > 0) {
      const bounds = allCoords.reduce(
        (b, c) => b.extend(c as [number, number]),
        new mapboxgl.LngLatBounds(allCoords[0] as [number, number], allCoords[0] as [number, number]),
      );
      map.fitBounds(bounds, { padding: 80 });
    }

    zones.forEach((zone, i) => {
      addZoneLayers(`zone-${i}`, zone, ACTIVE_COLOR, activeLayerIds);
    });

    suggestions.forEach((suggestion, i) => {
      addZoneLayers(`suggestion-${i}`, suggestion, SUGGESTED_COLOR, suggestedLayerIds, true);
    });

    initToggle('toggle-active', activeLayerIds);
    initToggle('toggle-suggested', suggestedLayerIds);
  });

  /**
   * Adds fill, line, and label layers for a single zone polygon.
   * When `dashed` is true the outline uses a dash pattern to distinguish suggestions.
   */
  function addZoneLayers(
    sourceId: string,
    zone: ZoneEntry,
    color: string,
    layerBucket: string[],
    dashed = false,
  ) {
    const geometry = resolveGeometry(zone.boundary);
    if (!geometry) return;

    map.addSource(sourceId, {
      type: 'geojson',
      data: { type: 'Feature', geometry, properties: { name: zone.name } } as GeoJSON.Feature,
    });

    const fillId = `${sourceId}-fill`;
    const lineId = `${sourceId}-line`;
    const labelId = `${sourceId}-label`;

    map.addLayer({
      id: fillId,
      type: 'fill',
      source: sourceId,
      paint: { 'fill-color': color, 'fill-opacity': isDark ? 0.15 : 0.25 },
    });

    map.addLayer({
      id: lineId,
      type: 'line',
      source: sourceId,
      paint: {
        'line-color': color,
        'line-width': 2,
        ...(dashed ? { 'line-dasharray': [2, 2] } : {}),
      },
    });

    map.addLayer({
      id: labelId,
      type: 'symbol',
      source: sourceId,
      layout: {
        'text-field': zone.name,
        'text-size': 14,
        'text-font': ['DIN Pro Medium', 'Arial Unicode MS Regular'],
        'text-anchor': 'center',
      },
      paint: {
        'text-color': isDark ? '#F5F5F5' : '#262626',
        'text-halo-color': isDark ? '#000000' : '#FFFFFF',
        'text-halo-width': 1.5,
      },
    });

    layerBucket.push(fillId, lineId, labelId);
  }

  /** Wires a toggle button to show/hide a set of Mapbox layers. */
  function initToggle(buttonId: string, layerIds: string[]) {
    const btn = document.getElementById(buttonId);
    if (!btn) return;

    let visible = true;

    btn.addEventListener('click', () => {
      visible = !visible;
      const value = visible ? 'visible' : 'none';
      for (const id of layerIds) {
        map.setLayoutProperty(id, 'visibility', value);
      }
      btn.style.opacity = visible ? '1' : '0.4';
    });
  }

  /**
   * Unwraps a GeoJSON value that may be a FeatureCollection, Feature, or bare
   * Geometry and returns the first concrete Geometry found.
   */
  function resolveGeometry(obj: unknown): GeoJSON.Geometry | null {
    const g = obj as Record<string, unknown>;
    if (!g || !g.type) return null;
    if (g.type === 'FeatureCollection') {
      const fc = obj as GeoJSON.FeatureCollection;
      return fc.features.length > 0 ? fc.features[0].geometry : null;
    }
    if (g.type === 'Feature') return (obj as GeoJSON.Feature).geometry;
    return obj as GeoJSON.Geometry;
  }

  /** Extracts [lng, lat] pairs, unwrapping FeatureCollection/Feature if needed. */
  function extractCoordinates(geom: unknown): number[][] {
    const resolved = resolveGeometry(geom);
    if (!resolved) return [];
    if (resolved.type === 'Polygon') return (resolved as GeoJSON.Polygon).coordinates.flat();
    if (resolved.type === 'MultiPolygon') return (resolved as GeoJSON.MultiPolygon).coordinates.flat(2);
    if (resolved.type === 'LineString') return (resolved as GeoJSON.LineString).coordinates;
    if (resolved.type === 'MultiLineString') return (resolved as GeoJSON.MultiLineString).coordinates.flat();
    if (resolved.type === 'Point') return [(resolved as GeoJSON.Point).coordinates];
    return [];
  }
</script>
