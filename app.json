{
  "expo": {
    "name": "Szpont",
    "slug": "szpont",
    "scheme": "szpont",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.szpont",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "package": "app.szpont"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "87534a4a-d0cd-4aa4-b261-0bd2d7392486"
      }
    },
    "owner": "vybe-social",
    "plugins": [
      "expo-sqlite",
      "expo-router",
      "expo-system-ui",
      "expo-localization",
      "expo-image",
      "expo-apple-authentication",
      "expo-video",
      "expo-asset",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "We use your location to detect when you're in a Szpont zone.",
          "locationWhenInUsePermission": "We use your location to show you nearby Szpont zones.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
